# Copy this file to .env.local and fill in values.
# .env.local is gitignored; .env.example is safe to commit.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# DataForSEO
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
SERPAPI_KEY= # optional

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=

# LLM (optional in V1)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
LITELLM_PROXY_URL=

# Google Cloud / OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps & Places
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# Firecrawl
FIRECRAWL_API_KEY=

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=

# Outscraper
OUTSCRAPER_API_KEY=

# Data365
DATA365_ACCESS_TOKEN=

# Resend (transactional email)
RESEND_API_KEY=

# Cron
CRON_SECRET=

# Feature flags
VERTICALIZATION_ENABLED=false
# Gates client-facing transactional emails (waitlist confirmation, welcome,
# trial reminders) behind the sendEmail() gateway. Admin-initiated flows and
# user-initiated auth (self-service magic link) bypass via overrideClientEmailPause.
# false in production (Chris's Resend drip handles marketing), true in dev/preview.
CLIENT_EMAILS_ENABLED=true
