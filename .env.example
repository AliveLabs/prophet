# Copy this file to .env.local and fill in values.
# .env.local is gitignored; .env.example is safe to commit.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# DataForSEO
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
SERPAPI_KEY= # optional

# Stripe
# Generated by `npx tsx scripts/stripe/setup.ts` — see scripts/stripe/README.md.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Ticket (restaurants) — 6 prices
STRIPE_PRICE_ID_TICKET_ENTRY_MONTHLY=
STRIPE_PRICE_ID_TICKET_ENTRY_ANNUAL=
STRIPE_PRICE_ID_TICKET_MID_MONTHLY=
STRIPE_PRICE_ID_TICKET_MID_ANNUAL=
STRIPE_PRICE_ID_TICKET_TOP_MONTHLY=
STRIPE_PRICE_ID_TICKET_TOP_ANNUAL=

# Neat (liquor stores) — 6 prices
STRIPE_PRICE_ID_NEAT_ENTRY_MONTHLY=
STRIPE_PRICE_ID_NEAT_ENTRY_ANNUAL=
STRIPE_PRICE_ID_NEAT_MID_MONTHLY=
STRIPE_PRICE_ID_NEAT_MID_ANNUAL=
STRIPE_PRICE_ID_NEAT_TOP_MONTHLY=
STRIPE_PRICE_ID_NEAT_TOP_ANNUAL=

# Customer Portal configurations (per brand — distinct branding/headlines)
STRIPE_PORTAL_CONFIG_TICKET=
STRIPE_PORTAL_CONFIG_NEAT=

# LLM (optional in V1)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
LITELLM_PROXY_URL=

# Google Cloud / OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps & Places
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# Firecrawl
FIRECRAWL_API_KEY=

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=

# Outscraper
OUTSCRAPER_API_KEY=

# Data365
DATA365_ACCESS_TOKEN=

# Resend (transactional email)
RESEND_API_KEY=

# Cron
CRON_SECRET=

# PostHog (product analytics + session replay)
# NEXT_PUBLIC_POSTHOG_KEY is the project API key (phc_...), browser-safe.
# NEXT_PUBLIC_POSTHOG_HOST points at our /ingest reverse proxy (configured in
# next.config.ts) to bypass tracker-blocking extensions. In local dev you can
# set this to https://us.i.posthog.com to bypass the proxy entirely.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# Feature flags
VERTICALIZATION_ENABLED=false
# Gates client-facing transactional emails (waitlist confirmation, welcome,
# trial reminders) behind the sendEmail() gateway. Admin-initiated flows and
# user-initiated auth (self-service magic link) bypass via overrideClientEmailPause.
# false in production (Chris's Resend drip handles marketing), true in dev/preview.
CLIENT_EMAILS_ENABLED=true
# Gates the product-side mirror into `marketing.contacts`. Must stay false until
# Chris's Phase 3 marketing schema migration has been applied to the target
# Supabase project AND `marketing` has been added to Settings -> API ->
# Exposed schemas. When false, upsertMarketingContact() no-ops silently.
MARKETING_CONTACTS_ENABLED=false
